{
  "name": "inkbranch-final",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:host": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "start:host": "next start --hostname 0.0.0.0",
    "lint": "eslint",
    "user:list": "node --env-file=.env.local scripts/list-users.mjs",
    "user:role": "node --env-file=.env.local scripts/set-user-role.mjs",
    "user:password:check": "node --env-file=.env.local scripts/user-password.mjs check",
    "user:password:set": "node --env-file=.env.local scripts/user-password.mjs set",
    "db:push": "drizzle-kit push --force",
    "db:push:review": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:export": "drizzle-kit export"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.3",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
